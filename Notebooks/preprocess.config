{
    "window_size": 48,
    "stride":24,
    "correlation_threshold": 0.25,
    "doppler_bins":128,
    "max_lag": 512,                  
    "test_size": 0.1,
    "val_size": 0.1,
    "random_seed": 0,
    "dataset_name": "radar_windows_corr_stride",
    "file_name": "dataset",
    "augmentations":{
        "use_augmentation": true,
        "aug_amp_scale": true,
        "aug_noise": true,
        "aug_noise_std": 0.005,
        "aug_time_shift": true,
        "aug_time_shift_max": 2,
        "aug_freq_shift": false,
        "aug_freq_shift_max": 1
    },
    "REMARKS": "Augmentation | Normalization."
}

